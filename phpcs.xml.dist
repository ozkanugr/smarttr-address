<?xml version="1.0"?>
<ruleset name="SmartTR Address">
    <description>WordPress Coding Standards for SmartTR Address (free edition).</description>

    <!-- Scan these paths. -->
    <file>.</file>

    <!-- Ignore generated / third-party directories. -->
    <exclude-pattern>./vendor/*</exclude-pattern>
    <exclude-pattern>./node_modules/*</exclude-pattern>
    <exclude-pattern>./assets/vendor/*</exclude-pattern>
    <exclude-pattern>./tests/bootstrap.php</exclude-pattern>

    <!-- PHP version target. -->
    <config name="testVersion" value="8.1-"/>

    <!-- Apply WordPress-Extra (includes WordPress-Core) + WordPress-Docs. -->
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <!-- Plugin text domain. -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="smarttr-address"/>
        </properties>
    </rule>

    <!-- Global function / variable / constant prefix. -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array" value="cecomsmarad,Cecomsmarad,CECOMSMARAD"/>
        </properties>
    </rule>

    <!-- Minimum WP version for deprecated checks. -->
    <config name="minimum_supported_wp_version" value="6.4"/>
</ruleset>
